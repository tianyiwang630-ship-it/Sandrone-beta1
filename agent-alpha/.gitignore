# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# MCP 自动生成的配置
.auto-config.json

# 工作空间：agent 运行和个人产物，不进 git
/workspace/

# agent-alpha 本地运行目录
/bin/
/userfile/
/cache/
/tools/
/data/
/state/
/config/appdata/
# home 只忽略运行态内容，但保留 skills
/home/*
!/home/.agents/
!/home/.agents/skills/
!/home/.agents/skills/**

# 输入输出文件目录
/input files/
/output files/
/temp/

# MCP 子模块
mcp-servers/**/node_modules/
mcp-servers/**/.venv/
mcp-servers/**/.auto-config.json
mcp-servers/**/__pycache__/

# Playwright 运行时状态只保留本地，不进 git
mcp-servers/playwright/state/profiles/
mcp-servers/playwright/state/storage/*
!mcp-servers/playwright/state/storage/.gitkeep
mcp-servers/playwright/temp/

# 日志
*.log
logs/
/session-log/

# 环境变量
.env
.env.local
config/runtime_env.local.json

# 系统文件
.DS_Store
Thumbs.db

# 测试
.pytest_cache/
.coverage
htmlcov/
